<h1>Bermudas</h1>

<div class="produtos">
    {{#each produtos}}
        {{#if this.nome}}
            <div class="produto-card">
                <h2>{{this.nome}}</h2>
                <p class="preco">R$ {{this.preco}}</p>
                <button>Adicionar ao Carrinho</button>
            </div>
        {{/if}}
    {{/each}}
</div>

<style>
    .produtos {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        padding: 20px;
    }
    
    .produto-card {
        border: 1px solid #ddd;
        padding: 15px;
        border-radius: 8px;
        text-align: center;
    }
    
    .preco {
        font-size: 1.5em;
        color: #27ae60;
        font-weight: bold;
    }
</style>